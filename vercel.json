{
  "functions": {
    "app/api/**/*.ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "app/api/emissor/laudos/*/pdf/route.ts": {
      "memory": 2048,
      "maxDuration": 60,
      "includeFiles": "node_modules/.pnpm/**/@sparticuz+chromium*/node_modules/@sparticuz/chromium/bin/**"
    },
    "app/api/avaliacao/relatorio-impressao/route.ts": {
      "memory": 2048,
      "maxDuration": 60,
      "includeFiles": "node_modules/.pnpm/**/@sparticuz+chromium*/node_modules/@sparticuz/chromium/bin/**"
    },
    "app/api/entidade/lote/*/relatorio-individual/route.ts": {
      "memory": 2048,
      "maxDuration": 60,
      "includeFiles": "node_modules/.pnpm/**/@sparticuz+chromium*/node_modules/@sparticuz/chromium/bin/**"
    }
  },
  "buildCommand": "pnpm build:prod",
  "installCommand": "pnpm install --frozen-lockfile --prefer-offline"
}
