# Example .env.local for running the app locally using production Neon DB
# WARNING: do NOT commit secrets to git. Use this file as a template only.

# Use the production Neon DB connection string here if you really want to point to production
# Example: postgresql://neondb_owner:secret@ep-.../neondb?sslmode=require
DATABASE_URL="postgresql://neondb_owner:REDACTED@ep-divine-sky-acuderi7-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# WARNING: Setting LOCAL_DATABASE_URL to the Neon production string will make your local development run against production data. Use with EXTREME CAUTION.
LOCAL_DATABASE_URL=postgresql://neondb_owner:REDACTED@ep-divine-sky-acuderi7-pooler.sa-east-1.aws.neondb?sslmode=require&channel_binding=require

# Opt-in: set to 'true' to allow using DATABASE_URL in development (bypasses LOCAL_DATABASE_URL)
# Use only if you are the sole user and accept the risk.
ALLOW_PROD_DB_LOCAL=true

# Other local overrides (if needed)
NODE_ENV=development

# ========================================
# ASAAS PAYMENT GATEWAY - DEV (Sandbox)
# ========================================
# Webhook Asaas: QWorkSandAsaas (DEV / ngrok)
# Cadastre o token abaixo em:
#   sandbox.asaas.com → Configurações → Integrações → Webhooks → QWorkSandAsaas
#   campo 'Token de Autenticação'
#
# API Key (mesma para DEV e PROD enquanto Sandbox)
ASAAS_API_KEY=sua_api_key_sandbox_aqui
ASAAS_API_URL=https://api-sandbox.asaas.com/v3

# Token do webhook 'QWorkSandAsaas' - gere um valor e cadastre no painel Asaas
ASAAS_WEBHOOK_SECRET=seu_token_webhook_dev_aqui

# URL pública via ngrok (expõe localhost para o Asaas)
# ⚠️  Atualizar aqui E no painel Asaas toda vez que o ngrok reiniciar
NEXT_PUBLIC_APP_URL=https://SEU-ID.ngrok-free.app
NEXT_PUBLIC_BASE_URL=https://SEU-ID.ngrok-free.app
